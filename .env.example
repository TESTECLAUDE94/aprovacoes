# Supabase — pegue em: https://supabase.com/dashboard/project/SEU_PROJETO/settings/database
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="seu-secret-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Resend (envio de email) — https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxx"
FROM_EMAIL="noreply@seudominio.com.br"

# URL pública do app (na Vercel será preenchido automaticamente)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
